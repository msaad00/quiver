        "integrity_keys_present": ["approved_payload_hash", "state_hash"],
        "idempotency_keys_present": ["remediation_key"],
        "remediation_key_matches_idempotency": true,
        "audit_key_matches_remediation": true,
        "planned_steps_absent": true
      }
    },
