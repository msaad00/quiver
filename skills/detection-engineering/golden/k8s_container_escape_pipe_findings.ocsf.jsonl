{"activity_id":1,"category_uid":2,"category_name":"Findings","class_uid":2004,"class_name":"Detection Finding","type_uid":200401,"severity_id":5,"status_id":1,"time":1775797830000,"metadata":{"version":"1.8.0","uid":"det-k8s-r2-hostpath-injection-9c5a6fa5-7bacbd6e","product":{"name":"cloud-ai-security-skills","vendor_name":"msaad00/cloud-ai-security-skills","feature":{"name":"detect-container-escape-k8s"}},"labels":["detection-engineering","kubernetes","container-escape","r2-hostpath-injection"]},"finding_info":{"uid":"det-k8s-r2-hostpath-injection-9c5a6fa5-7bacbd6e","title":"Patch introduced a risky hostPath mount on a Kubernetes workload","desc":"Actor 'system:serviceaccount:payments:builder' patched deployments 'api' in namespace 'payments' to reference host paths /var/lib/containerd. Kubernetes documents hostPath as a high-risk escape hatch, and these paths map directly to host resources commonly abused during container escape. (MITRE T1611)","types":["k8s-r2-hostpath-injection"],"first_seen_time":1775797830000,"last_seen_time":1775797830000,"attacks":[{"version":"v14","tactic":{"name":"Privilege Escalation","uid":"TA0004"},"technique":{"name":"Escape to Host","uid":"T1611"}}]},"observables":[{"name":"actor.name","type":"Other","value":"system:serviceaccount:payments:builder"},{"name":"resource.type","type":"Other","value":"deployments"},{"name":"resource.name","type":"Other","value":"api"},{"name":"namespace","type":"Other","value":"payments"},{"name":"host_paths","type":"Other","value":"/var/lib/containerd"},{"name":"rule","type":"Other","value":"r2-hostpath-injection"}],"evidence":{"events_observed":1,"first_seen_time":1775797830000,"last_seen_time":1775797830000,"raw_events":[]}}
{"activity_id":1,"category_uid":2,"category_name":"Findings","class_uid":2004,"class_name":"Detection Finding","type_uid":200401,"severity_id":4,"status_id":1,"time":1775797860000,"metadata":{"version":"1.8.0","uid":"det-k8s-r3-ephemeral-container-ff8d9819-edbb2114","product":{"name":"cloud-ai-security-skills","vendor_name":"msaad00/cloud-ai-security-skills","feature":{"name":"detect-container-escape-k8s"}},"labels":["detection-engineering","kubernetes","container-escape","r3-ephemeral-container"]},"finding_info":{"uid":"det-k8s-r3-ephemeral-container-ff8d9819-edbb2114","title":"Ephemeral container was added to a running pod","desc":"Actor 'alice@example.com' modified the `pods/ephemeralcontainers` subresource for pod 'api-7d9b' in namespace 'payments', adding ephemeral container(s): debugger. Kubernetes creates ephemeral containers through a special API handler commonly reached through `kubectl debug`; in an adversary flow this is container deployment for interactive execution on a live target. (MITRE T1610)","types":["k8s-r3-ephemeral-container"],"first_seen_time":1775797860000,"last_seen_time":1775797860000,"attacks":[{"version":"v14","tactic":{"name":"Execution","uid":"TA0002"},"technique":{"name":"Deploy Container","uid":"T1610"}}]},"observables":[{"name":"actor.name","type":"Other","value":"alice@example.com"},{"name":"pod.name","type":"Other","value":"api-7d9b"},{"name":"namespace","type":"Other","value":"payments"},{"name":"ephemeral_containers","type":"Other","value":"debugger"},{"name":"rule","type":"Other","value":"r3-ephemeral-container"}],"evidence":{"events_observed":1,"first_seen_time":1775797860000,"last_seen_time":1775797860000,"raw_events":[]}}
